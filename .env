# ============================================================
# OpsTune - Environment Variables
# ============================================================

# ------------------------------------------------------------
# Hugging Face (fine-tuning)
# ------------------------------------------------------------
HF_TOKEN=

OPSTUNE_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
OPSTUNE_RUN_NAME=opstune-qwen25-3b-lora-v1


# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=                       # Główny klucz (OpenAI lub inny provider)

# Opcjonalne nadpisania
# For finetuned model: set OPENAI_MODEL=opstune and OPENAI_BASE_URL to local server
# For OpenAI: comment out BASE_URL and set MODEL to gpt-4o-mini
OPENAI_MODEL=opstune
OPENAI_BASE_URL=http://localhost:8000/v1


# ------------------------------------------------------------
# Fireworks AI (alternatywa dla OpenAI)
# ------------------------------------------------------------
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1


# ------------------------------------------------------------
# Groq (szybki i tani inference)
# ------------------------------------------------------------
GROQ_API_KEY=


# ------------------------------------------------------------
# Backend
# ------------------------------------------------------------
ENVIRONMENT=development
